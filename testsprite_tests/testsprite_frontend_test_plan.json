[
  {
    "id": "TC001",
    "title": "Register a new user successfully and reach the dashboard",
    "description": "Verifies a new user can register with valid name, email, and password and is redirected to the dashboard.",
    "category": "User Registration",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /register"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Crear cuenta\" is visible"
      },
      {
        "type": "action",
        "description": "Fill \"Test User\" into the name input field"
      },
      {
        "type": "action",
        "description": "Fill \"testsprite.user+reg1@example.com\" into the email input field"
      },
      {
        "type": "action",
        "description": "Fill \"securepw\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click \"Crear cuenta\" button to submit"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      }
    ]
  },
